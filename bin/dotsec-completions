#!/usr/bin/env zsh
# ─── dotsec completions ─────────────────────────────────
# Generate shell completions for dotsec
# Usage: source <(dotsec completions zsh)

_dotsec_completions() {
    local commands="new load unload list spawn board dashboard proxy browser exegol tmux log secrets rotate archive stop restart completions info help"
    local proxy_sub="up down status logs"
    local board_sub="up start down stop reload status"
    local exegol_sub="exec shell setup"
    local tmux_sub="attach create kill ls"

    if [[ $words[CURRENT-1] == "dotsec" ]]; then
        compadd -- $commands
    elif [[ $words[CURRENT-2] == "dotsec" ]]; then
        case $words[CURRENT-1] in
            proxy)    compadd -- $proxy_sub;;
            board)    compadd -- $board_sub;;
            dashboard) compadd -- $board_sub;;
            exegol)   compadd -- $exegol_sub;;
            tmux)     compadd -- $tmux_sub;;
            rotate) compadd -- all token mitmweb ssh ca;;
            spawn|load|browser|new|secrets|rotate|archive|stop|restart)
                local targets=()
                for d in ${WORKSPACE_ROOT:-/workspace}/*/.env(N); do
                    targets+=($(basename $(dirname $d)))
                done
                compadd -- $targets
                ;;
        esac
    elif [[ $words[CURRENT-2] == "tmux" ]]; then
        case $words[CURRENT-1] in
            attach|a|kill|k)
                local sessions=(${(f)"$(tmux ls 2>/dev/null | cut -d: -f1)"})
                compadd -- $sessions
                ;;
        esac
    fi
}

case "${1:-}" in
    zsh) compdef _dotsec_completions dotsec;;
    bash) echo "[!] Bash not yet supported, use zsh" >&2;;
    *) echo "Usage: dotsec completions zsh|bash" >&2;;
esac
