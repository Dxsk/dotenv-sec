#!/usr/bin/env bash
# ─── dotsec ─── dotenv-sec launcher ─────────────────────
set -euo pipefail

DOTSEC_HOME="${DOTSEC_HOME:-$HOME/Documents/github.com/Dxsk/dotenv-sec}"
DOTSEC_CONFIG="${DOTSEC_CONFIG:-$HOME/.config/dotenvsec}"
VERSION="0.1.0"

# ── Colors ──────────────────────────────────────────────
BOLD="\033[1m"; RED="\033[31m"; GREEN="\033[32m"; YELLOW="\033[33m"
BLUE="\033[34m"; CYAN="\033[36m"; RESET="\033[0m"

# ── Global config (always sourced, overridden per-engagement) ──
__dotsec_load_global() {
    if [[ -f "${DOTSEC_CONFIG}/config" ]]; then
        source "${DOTSEC_CONFIG}/config"
    fi
}
__dotsec_load_global

# ── Help ────────────────────────────────────────────────
usage() {
    cat <<EOF
${BOLD}dotsec${RESET} v${VERSION}: Pentest environment launcher

${BOLD}USAGE${RESET}
  dotsec <command> [args]

${BOLD}COMMANDS${RESET}
  ${GREEN}new${RESET}     <target> [domain]    Init engagement workspace + tmux + proxy
  ${GREEN}load${RESET}    <target>             Source .env.engagement
  ${GREEN}unload${RESET}                       Unset engagement vars
  ${GREEN}list${RESET}                         List all engagements in workspace

  ${GREEN}spawn${RESET}   [session]             Instant pentest tmux session (6 windows)
  ${GREEN}proxy${RESET}   up|down|status|logs  Manage mitmproxy container
  ${GREEN}browser${RESET} [target]             Launch Chromium (routed through proxy)
  ${GREEN}board${RESET}   up|down|reload|status Homer dashboard (http://127.0.0.1:9997)
  ${GREEN}exegol${RESET}  exec <cmd>           Run command inside Exegol container
  ${GREEN}exegol${RESET}  shell                Open shell in Exegol

  ${GREEN}tmux${RESET}    attach|create|kill|ls tmux session management
  ${GREEN}log${RESET}     <cmd...>             Run command + log to commands.log

  ${GREEN}info${RESET}                         Show current engagement info
  ${GREEN}help${RESET}                         This message

${BOLD}QUICKSTART${RESET}
  dotsec new mytarget example.com
  dotsec proxy up
  dotsec browser

${BOLD}CONFIG${RESET}
  DOTSEC_HOME=${DOTSEC_HOME}
EOF
    exit 0
}

# ── Proxy commands ──────────────────────────────────────
proxy_up() {
    local target="${TARGET:-default}"
    local proxy_port="${PROXY_PORT:-9999}"
    local web_port="${WEB_PORT:-9998}"

    # Create docker network if not exists
    docker network inspect dotsec-proxy-net &>/dev/null || \
        docker network create dotsec-proxy-net

    echo -e "${CYAN}[*] Starting mitmproxy for ${target}...${RESET}"
    local ws="${WORKSPACE:-/workspace/${target}}"
    mkdir -p "${ws}/proxy/certs" "${ws}/proxy/flows"
    TARGET="${target}" \
        PROXY_PORT="${proxy_port}" \
        WEB_PORT="${web_port}" \
        PROXY_CERTS="${ws}/proxy/certs" \
        PROXY_FLOWS="${ws}/proxy/flows" \
        docker compose -f "${DOTSEC_HOME}/mitmproxy/docker-compose.yml" \
        --project-name "dotsec-${target}" up -d --build

    echo -e "${GREEN}[+] Proxy ready${RESET}"
    echo -e "  Proxy  → ${YELLOW}http://127.0.0.1:${proxy_port}${RESET}"
    echo -e "  Web UI → ${YELLOW}http://127.0.0.1:${web_port}${RESET}"
    echo -e "  CA PEM → ${YELLOW}$(pwd)/certs/mitmproxy-ca.pem${RESET}"

    # Auto-reload Homer dashboard
    docker ps --filter "name=dotsec-homer" --format '{{.Names}}' 2>/dev/null | grep -q . && {
        __homer_gen_config >/dev/null 2>&1
        docker restart dotsec-homer >/dev/null 2>&1 || true
    }
}

proxy_down() {
    local target="${TARGET:-default}"
    docker compose -f "${DOTSEC_HOME}/mitmproxy/docker-compose.yml" \
        --project-name "dotsec-${target}" down
    echo -e "${GREEN}[+] Proxy stopped for ${target}${RESET}"
}

proxy_status() {
    local target="${TARGET:-default}"
    docker ps --filter "name=mitmproxy-${target}" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
}

proxy_logs() {
    local target="${TARGET:-default}"
    docker logs -f "mitmproxy-${target}"
}

# ── Engagement commands ─────────────────────────────────
cmd_new() {
    local target="${1:-}"
    local domain="${2:-${target}}"

    if [[ -z "$target" ]]; then
        echo -e "${RED}[!] Usage: dotsec new <target> [domain]${RESET}"
        exit 1
    fi

    local ws="/workspace/${target}"

    echo -e "${BOLD}${GREEN}╔══════════════════════════════════════╗${RESET}"
    echo -e "${BOLD}${GREEN}║  New Engagement: ${target}${RESET}"
    echo -e "${BOLD}${GREEN}╚══════════════════════════════════════╝${RESET}"

    # 1. Workspace structure
    echo -e "${CYAN}[1/4] Creating workspace...${RESET}"
    mkdir -p "${ws}"/{recon/{passive,active},scans/{ports,web,vuln},exploits/{pocs,payloads},loot/{credentials,data},logs,report/assets,replays/{recon,scan,exploit,post,report,monitor}}

    # 2. Copy and fill .env
    echo -e "${CYAN}[2/4] Setting up dotenv...${RESET}"
    cp "${DOTSEC_HOME}/templates/.env.engagement" "${ws}/.env"
    sed -i "s/acme-corp/${target}/g" "${ws}/.env"
    sed -i "s/acme-corp\.com/${domain}/g" "${ws}/.env"
    sed -i "s|/workspace/acme-corp|/workspace/${target}|g" "${ws}/.env"

    # Merge global config defaults (only if key not already set)
    __dotsec_load_global
    [[ -n "${UA:-}" ]] && sed -i "s|H1-yourhandle|${UA}|g" "${ws}/.env"
    [[ -n "${EXEGOL_CONTAINER:-}" ]] && sed -i "s|exegol-default|${EXEGOL_CONTAINER}|g" "${ws}/.env"
    [[ -n "${PROXY_PORT:-}" ]] && sed -i "s|PROXY_PORT=\"9999\"|PROXY_PORT=\"${PROXY_PORT}\"|g" "${ws}/.env"
    [[ -n "${WEB_PORT:-}" ]] && sed -i "s|WEB_PORT=\"9998\"|WEB_PORT=\"${WEB_PORT}\"|g" "${ws}/.env"

    # 3. ENGAGEMENT.md
    cat > "${ws}/ENGAGEMENT.md" <<DOC
# Engagement: ${target}

- **Date**: $(date '+%Y-%m-%d %H:%M')
- **Domain**: ${domain}
- **Workspace**: ${ws}
- **Proxy**: http://127.0.0.1:\${PROXY_PORT:-8080}

## Scope
TODO

## Rules of Engagement
TODO

## User-Agent
\${UA:-not set}
DOC

    # 4. tmux session
    echo -e "${CYAN}[3/4] Creating tmux session...${RESET}"
    tmux has-session -t "${target}" 2>/dev/null && tmux kill-session -t "${target}"
    tmux new-session -d -s "${target}" -n recon
    tmux new-window  -t "${target}" -n scan
    tmux new-window  -t "${target}" -n exploit
    tmux new-window  -t "${target}" -n post
    tmux new-window  -t "${target}" -n report
    tmux new-window  -t "${target}" -n monitor

    # Load env in each tmux window
    for w in recon scan exploit post report monitor; do
        tmux send-keys -t "${target}:${w}" "source ${ws}/.env && export TARGET=${target} DOMAIN=${domain}" Enter
    done

    # 5. Proxy setup
    echo -e "${CYAN}[4/4] Preparing proxy links...${RESET}"
    mkdir -p "${ws}/proxy" && ln -sfn "${ws}/proxy" "$(pwd)/proxy-${target}" 2>/dev/null || true

    echo ""
    echo -e "${BOLD}${GREEN}[✓] Engagement '${target}' ready!${RESET}"
    echo ""
    echo -e "  ${BOLD}Workspace${RESET}  → ${ws}"
    echo -e "  ${BOLD}Load env${RESET}    → ${YELLOW}dotsec load ${target}${RESET}"
    echo -e "  ${BOLD}Start proxy${RESET}  → ${YELLOW}dotsec proxy up${RESET}"
    echo -e "  ${BOLD}Attach tmux${RESET}  → ${YELLOW}dotsec tmux attach${RESET}"
    echo -e "  ${BOLD}Browser${RESET}     → ${YELLOW}dotsec browser${RESET}"
    echo -e "  ${BOLD}Dashboard${RESET}   → ${YELLOW}dotsec board reload${RESET}"
    echo ""

    # Auto-reload Homer if running
    docker ps --filter "name=dotsec-homer" --format '{{.Names}}' 2>/dev/null | grep -q . && {
        __homer_gen_config >/dev/null 2>&1
        docker restart dotsec-homer >/dev/null 2>&1 || true
    }
}

cmd_load() {
    local target="${1:-${TARGET:-}}"
    if [[ -z "$target" ]]; then
        echo -e "${RED}[!] Usage: dotsec load <target>${RESET}"
        exit 1
    fi
    local envfile="/workspace/${target}/.env"
    if [[ ! -f "$envfile" ]]; then
        echo -e "${RED}[!] No .env found for ${target} at ${envfile}${RESET}"
        echo -e "  Run ${YELLOW}dotsec new ${target}${RESET} first"
        exit 1
    fi
    __dotsec_load_global
    source "$envfile"
    echo -e "${GREEN}[+] Loaded engagement: ${TARGET}${RESET}"
    echo -e "  Workspace → ${WORKSPACE}"
    echo -e "  Proxy    → ${HTTP_PROXY}"
    echo -e "  UA       → ${UA}"
    echo ""
    echo -e "To keep vars in your shell: ${YELLOW}source <(dotsec load ${target})${RESET}"
}

cmd_unload() {
    unset TARGET DOMAIN IP UA PROGRAM PROXY_PORT WEB_PORT HTTP_PROXY HTTPS_PROXY NO_PROXY WORKSPACE
    echo -e "${GREEN}[+] Engagement vars unset${RESET}"
}

cmd_list() {
    echo -e "${BOLD}Engagements:${RESET}"
    for d in /workspace/*/; do
        [[ -d "$d" ]] || continue
        local name=$(basename "$d")
        local env="${d}.env"
        if [[ -f "$env" ]]; then
            local domain=$(grep -oP 'DOMAIN="?\K[^"]+' "$env" 2>/dev/null || echo "?")
            echo -e "  ${CYAN}${name}${RESET}  → ${domain}"
        else
            echo -e "  ${CYAN}${name}${RESET}  (no .env)"
        fi
    done
}

# ── Browser ──────────────────────────────────────────────
cmd_browser() {
    local target="${1:-${TARGET:-}}"
    if [[ -z "$target" ]]; then
        echo -e "${RED}[!] Usage: dotsec browser <target>  (or dotsec load first)${RESET}"
        exit 1
    fi
    local ws="/workspace/${target}"

    # Ensure proxy is up
    if ! docker ps --filter "name=mitmproxy-${target}" --format '{{.Names}}' | grep -q .; then
        echo -e "${YELLOW}[!] Proxy not running. Starting...${RESET}"
        TARGET="${target}" proxy_up
    fi

    local proxy_host="mitmproxy-${target}"
    docker run --rm \
        --network dotsec-proxy-net \
        -e HTTP_PROXY="http://${proxy_host}:8080" \
        -e HTTPS_PROXY="http://${proxy_host}:8080" \
        -v "${ws}/proxy/certs:/certs:ro" \
        -p 9222:9222 \
        dotenv-sec/chromium:latest
}

# ── Exegol ───────────────────────────────────────────────
cmd_exegol() {
    local action="${1:-shell}"; shift || true
    local container="${EXEGOL_CONTAINER:-exegol}"

    case "$action" in
        exec)
            docker exec -it "$container" "$@"
            ;;
        shell)
            docker exec -it "$container" zsh
            ;;
        *)
            echo -e "${RED}[!] Usage: dotsec exegol exec|shell${RESET}"
            exit 1
            ;;
    esac
}

# ── Spawn ─────────────────────────────────────────────────
# Instant pentest-ready tmux session, with or without engagement loaded
cmd_spawn() {
    local session_name="${1:-${TARGET:-pentest}}"
    local ws="${WORKSPACE:-}"
    local envfile="${ws}/.env"

    # Kill existing session with same name to get a fresh one
    tmux has-session -t "$session_name" 2>/dev/null && tmux kill-session -t "$session_name"

    echo -e "${CYAN}[*] Spawning tmux session: ${session_name}${RESET}"

    # Create session with 6 windows
    tmux new-session -d -s "$session_name" -n recon
    tmux new-window  -t "$session_name" -n scan
    tmux new-window  -t "$session_name" -n exploit
    tmux new-window  -t "$session_name" -n post
    tmux new-window  -t "$session_name" -n report
    tmux new-window  -t "$session_name" -n monitor

    # Source engagement .env in each window if available
    if [[ -n "$ws" ]] && [[ -f "$envfile" ]]; then
        local load_cmd="source ${envfile}"
        for w in recon scan exploit post report monitor; do
            tmux send-keys -t "${session_name}:${w}" "$load_cmd; clear" Enter
        done
        echo -e "  ${GREEN}Env loaded${RESET} → ${ws}/.env"
    fi

    # Status bar: highlight session name
    tmux set-option -t "$session_name" status-right "#[fg=cyan]${session_name}#[default] | %H:%M"
    tmux set-option -t "$session_name" status-style "bg=#1a1a2e,fg=#e0e0e0"
    tmux set-option -t "$session_name" window-status-current-style "bg=#00ff87,fg=#0a0a0a,bold"

    # Attach
    tmux attach -t "$session_name"
}

# ── Tmux ─────────────────────────────────────────────────
cmd_tmux() {
    local action="${1:-}"; shift || true
    local target="${TARGET:-}"
    [[ -z "$target" ]] && target="${1:-}"

    case "$action" in
        attach|a)
            [[ -z "$target" ]] && { echo -e "${RED}[!] No target. dotsec load <target> first${RESET}"; exit 1; }
            tmux attach -t "$target"
            ;;
        create)
            [[ -z "$target" ]] && { echo -e "${RED}[!] Usage: dotsec tmux create <target>${RESET}"; exit 1; }
            tmux new-session -d -s "$target" -n recon
            tmux new-window -t "$target" -n scan
            tmux new-window -t "$target" -n exploit
            tmux new-window -t "$target" -n post
            tmux new-window -t "$target" -n report
            tmux new-window -t "$target" -n monitor
            echo -e "${GREEN}[+] Session ${target} created${RESET}"
            ;;
        kill|k)
            [[ -z "$target" ]] && { echo -e "${RED}[!] Usage: dotsec tmux kill <target>${RESET}"; exit 1; }
            tmux kill-session -t "$target"
            echo -e "${GREEN}[+] Session ${target} killed${RESET}"
            ;;
        ls|list)
            tmux ls 2>/dev/null || echo "No sessions"
            ;;
        *)
            echo -e "${RED}[!] Usage: dotsec tmux attach|create|kill|ls${RESET}"
            ;;
    esac
}

# ── Log ───────────────────────────────────────────────────
cmd_log() {
    local target="${TARGET:-}"
    [[ -z "$target" ]] && { echo -e "${RED}[!] No engagement loaded${RESET}"; exit 1; }
    local logfile="/workspace/${target}/logs/commands.log"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$logfile"
    eval "$@"
}

# ── Dashboard (Homer) ────────────────────────────────────
__homer_gen_config() {
    local config="${DOTSEC_HOME}/homer/config.yml"
    local base="${DOTSEC_HOME}/homer/config.base.yml"

    # Use base template if available, else inline
    if [[ -f "$base" ]]; then
        cp "$base" "$config"
    else
        cat > "$config" <<'YAML'
---
title: "dotenv-sec"
subtitle: "Pentest Dashboard"
logo: "assets/logo.png"
header: true
footer: false
columns: "auto"
connectivityCheck: true
theme: dark
colors:
  light:
    highlight-primary: "#00ff87"
    highlight-secondary: "#00d4ff"
    background: "#0a0a0f"
    card-background: "#1a1a2e"
    text: "#e0e0e0"
    text-header: "#00ff87"
    text-title: "#ffffff"
    text-subtitle: "#ccd6f6"
    card-shadow: "rgba(0,255,135,0.1)"
    link: "#00d4ff"
    link-hover: "#00ff87"
  dark:
    highlight-primary: "#00ff87"
    highlight-secondary: "#00d4ff"
    background: "#0a0a0f"
    card-background: "#1a1a2e"
    text: "#e0e0e0"
    text-header: "#00ff87"
    text-title: "#ffffff"
    text-subtitle: "#ccd6f6"
    card-shadow: "rgba(0,255,135,0.1)"
    link: "#00d4ff"
    link-hover: "#00ff87"
YAML
    fi

    # Inject services
    cat >> "$config" <<YAML

services:
YAML

    # Detection d'engagements actifs
    local found=0
    for d in /workspace/*/; do
        [[ -d "$d" ]] || continue
        local target=$(basename "$d")
        local envfile="${d}.env"
        local domain=""

        [[ -f "$envfile" ]] && domain=$(grep -oP 'DOMAIN="?\K[^"]+' "$envfile" 2>/dev/null || echo "")
        [[ -z "$domain" ]] && domain="${target}"

        # Check if proxy is running
        local proxy_status="down"
        docker ps --filter "name=mitmproxy-${target}" --format '{{.Names}}' 2>/dev/null | grep -q . && proxy_status="up"

        cat >> "$config" <<BLOCK
  - name: "${target}"
    icon: "fas fa-crosshairs"
    subtitle: "${domain}"
    items:
      - name: "Proxy: ${proxy_status}"
        icon: "fas fa-network-wired"
        subtitle: "127.0.0.1:9999"
        url: "http://127.0.0.1:9999"
        target: "_blank"
      - name: "mitmweb UI"
        icon: "fas fa-globe"
        subtitle: "127.0.0.1:9998"
        url: "http://127.0.0.1:9998"
        target: "_blank"
      - name: "Workspace"
        icon: "fas fa-folder"
        subtitle: "${target}"
        url: "file:///workspace/${target}"
      - name: "ENGAGEMENT.md"
        icon: "fas fa-file-alt"
        subtitle: "scope, rules"
        url: "file:///workspace/${target}/ENGAGEMENT.md"
BLOCK
        found=1
    done

    # Fallback if no engagements
    if [[ $found -eq 0 ]]; then
        cat >> "$config" <<YAML
  - name: "No engagements"
    icon: "fas fa-circle-notch"
    items:
      - name: "Create one"
        icon: "fas fa-plus"
        subtitle: "dotsec new <target>"
        url: "#"
YAML
    fi

    echo "  → ${config}"
}

cmd_dashboard() {
    local action="${1:-status}"

    case "$action" in
        up|start)
            echo -e "${CYAN}[*] Generating Homer config...${RESET}"
            __homer_gen_config

            echo -e "${CYAN}[*] Starting Homer dashboard...${RESET}"
            docker network inspect dotsec-proxy-net &>/dev/null || \
                docker network create dotsec-proxy-net

            docker compose -f "${DOTSEC_HOME}/homer/docker-compose.yml" \
                --project-name "dotsec-homer" up -d

            echo -e "${GREEN}[+] Dashboard ready${RESET}"
            echo -e "  → ${YELLOW}http://127.0.0.1:${HOMER_PORT:-9997}${RESET}"
            ;;
        down|stop)
            docker compose -f "${DOTSEC_HOME}/homer/docker-compose.yml" \
                --project-name "dotsec-homer" down
            echo -e "${GREEN}[+] Dashboard stopped${RESET}"
            ;;
        reload)
            echo -e "${CYAN}[*] Regenerating config + restarting...${RESET}"
            __homer_gen_config
            docker restart dotsec-homer 2>/dev/null || \
                { echo -e "${YELLOW}[!] Homer not running, starting...${RESET}"; cmd_dashboard up; }
            echo -e "${GREEN}[+] Dashboard reloaded${RESET}"
            ;;
        status)
            docker ps --filter "name=dotsec-homer" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
            ;;
        *)
            echo -e "${RED}[!] Usage: dotsec dashboard up|down|reload|status${RESET}"
            ;;
    esac
}
cmd_info() {
    echo -e "${BOLD}dotsec v${VERSION}${RESET}"
    echo ""
    echo -e "  ${BOLD}TARGET${RESET}     = ${TARGET:-not set}"
    echo -e "  ${BOLD}DOMAIN${RESET}     = ${DOMAIN:-not set}"
    echo -e "  ${BOLD}WORKSPACE${RESET}  = ${WORKSPACE:-not set}"
    echo -e "  ${BOLD}HTTP_PROXY${RESET} = ${HTTP_PROXY:-not set}"
    echo -e "  ${BOLD}UA${RESET}         = ${UA:-not set}"
    echo -e "  ${BOLD}EXEGOL${RESET}     = ${EXEGOL_CONTAINER:-not set}"
    echo ""
    echo -e "  ${BOLD}DOTSEC_HOME${RESET} = ${DOTSEC_HOME}"
    echo -e "  ${BOLD}DOTSEC_CONFIG${RESET}= ${DOTSEC_CONFIG} $([ -f "${DOTSEC_CONFIG}/config" ] && echo '(loaded)' || echo '(missing)')"
}

# ── Routeur ───────────────────────────────────────────────
case "${1:-help}" in
    new)          shift; cmd_new "$@";;
    load)         shift; cmd_load "$@";;
    unload)       cmd_unload;;
    list|ls)      cmd_list;;

    spawn)        shift; cmd_spawn "$@";;

    proxy)
        case "${2:-status}" in
            up)      proxy_up;;
            down)    proxy_down;;
            status)  proxy_status;;
            logs)    proxy_logs;;
            *)       echo -e "${RED}[!] dotsec proxy up|down|status|logs${RESET}";;
        esac
        ;;

    browser)      shift; cmd_browser "$@";;
    board)
        case "${2:-status}" in
            up|start|down|stop|reload|status)
                shift; cmd_dashboard "$@";;
            *)  echo -e "${RED}[!] dotsec board up|down|reload|status${RESET}";;
        esac
        ;;
    exegol)       shift; cmd_exegol "$@";;
    tmux)         shift; cmd_tmux "$@";;
    log)          shift; cmd_log "$@";;
    info)         cmd_info;;
    help|--help|-h) usage;;
    *)            echo -e "${RED}[!] Unknown command: $1${RESET}"; usage;;
esac
