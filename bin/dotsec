#!/usr/bin/env bash
# ─── dotsec ─── dotenv-sec launcher ─────────────────────
set -euo pipefail

DOTSEC_HOME="${DOTSEC_HOME:-$HOME/Documents/github.com/Dxsk/dotenv-sec}"
DOTSEC_CONFIG="${DOTSEC_CONFIG:-$HOME/.config/dotenvsec}"
VERSION="0.2.0"

# Workspace root: /workspace (Exegol) or fallback to ~/workspace
if [[ -z "${WORKSPACE_ROOT:-}" ]]; then
    if [[ -w "/workspace" ]] || [[ -d "/workspace" ]]; then
        WORKSPACE_ROOT="/workspace"
    else
        WORKSPACE_ROOT="${HOME}/workspace"
    fi
fi

DOTSEC_LIB="${DOTSEC_HOME}/lib"
for _m in ui core secrets dashboard proxy exegol engagement; do
    # shellcheck source=/dev/null
    source "${DOTSEC_LIB}/${_m}.sh"
done
__dotsec_load_global

# ── Routeur ───────────────────────────────────────────────
case "${1:-help}" in
    new)          shift; cmd_new "$@";;
    load)         shift; cmd_load "$@";;
    unload)       cmd_unload;;
    list|ls)      cmd_list;;

    spawn)        shift; cmd_spawn "$@";;

    proxy)
        case "${2:-status}" in
            up)      proxy_up;;
            down)    proxy_down;;
            status)  proxy_status;;
            logs)    proxy_logs;;
            *)       printf '%b\n' "${RED}[!] dotsec proxy up|down|status|logs${RESET}" >&2;;
        esac
        ;;

    browser)      shift; cmd_browser "$@";;
    board|dashboard)
        case "${2:-status}" in
            up|start|down|stop|reload|status)
                shift; cmd_dashboard "$@";;
            *)  printf '%b\n' "${RED}[!] dotsec board up|down|reload|status${RESET}" >&2;;
        esac
        ;;
    exegol)       shift; cmd_exegol "$@";;
    tmux)         shift; cmd_tmux "$@";;
    log)          shift; cmd_log "$@";;
    archive)      shift; cmd_archive "$@";;
    stop)         shift; cmd_stop "$@";;
    restart)      shift; cmd_restart "$@";;
    info)         cmd_info;;
    completions)  shift; exec "${DOTSEC_HOME}/bin/dotsec-completions" "$@";;
    help|--help|-h) usage;;
    *)            printf '%b\n' "${RED}[!] Unknown command: $1${RESET}" >&2; usage;;
esac
