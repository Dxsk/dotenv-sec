#!/usr/bin/env bash
# ─── dotsec ─── dotenv-sec launcher ─────────────────────
set -euo pipefail

DOTSEC_HOME="${DOTSEC_HOME:-$HOME/Documents/github.com/Dxsk/dotenv-sec}"
DOTSEC_CONFIG="${DOTSEC_CONFIG:-$HOME/.config/dotenvsec}"
VERSION="0.1.0"

# ── Colors ──────────────────────────────────────────────
BOLD=$'\033[1m'; RED=$'\033[31m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'
BLUE=$'\033[34m'; CYAN=$'\033[36m'; RESET=$'\033[0m'

# ── Shared helpers ──────────────────────────────────────
__docker_network_ensure() {
    local net="${1:-dotsec-proxy-net}"
    docker network inspect "$net" &>/dev/null || docker network create "$net"
}

__homer_reload_if_running() {
    if docker ps --filter "name=dotsec-homer" --format '{{.Names}}' 2>/dev/null | grep -q .; then
        __homer_gen_config >/dev/null 2>&1
        docker restart dotsec-homer >/dev/null 2>&1 || true
    fi
}

__env_domain() {
    local domain
    domain=$(grep -oP 'DOMAIN="?\K[^"]+' "$1" 2>/dev/null || echo "")
    echo "${domain}"
}

# ── Global config (always sourced, overridden per-engagement) ──
__dotsec_load_global() {
    if [[ -f "${DOTSEC_CONFIG}/config" ]]; then
        source "${DOTSEC_CONFIG}/config"
    fi
}
__dotsec_load_global

__require_docker() {
    if [[ -z "$(command -v docker)" ]]; then
        printf '%b\n' "${RED}[!] docker is required but not installed${RESET}" >&2
        exit 1
    fi
}

__require_tmux() {
    if [[ -z "$(command -v tmux)" ]]; then
        printf '%b\n' "${RED}[!] tmux is required but not installed${RESET}" >&2
        exit 1
    fi
}

# ── Help ────────────────────────────────────────────────
usage() {
    cat <<EOF
${BOLD}dotsec${RESET} v${VERSION}: Pentest environment launcher

${BOLD}USAGE${RESET}
  dotsec <command> [args]

${BOLD}COMMANDS${RESET}
  ${GREEN}new${RESET}     <target> [domain]    Init engagement workspace + tmux + proxy
  ${GREEN}load${RESET}    <target>             Source .env.engagement
  ${GREEN}unload${RESET}                       Unset engagement vars
  ${GREEN}list${RESET}                         List all engagements in workspace

  ${GREEN}spawn${RESET}   [session]             Instant pentest tmux session (6 windows)
  ${GREEN}proxy${RESET}   up|down|status|logs  Manage mitmproxy container
  ${GREEN}browser${RESET} [target]             Launch Chromium (routed through proxy)
  ${GREEN}board${RESET}   up|down|reload|status Homer dashboard (http://127.0.0.1:9997)
  ${GREEN}dashboard${RESET}                       Alias for board
  ${GREEN}exegol${RESET}  exec <cmd>           Run command inside Exegol container
  ${GREEN}exegol${RESET}  shell                Open shell in Exegol
  ${GREEN}exegol${RESET}  setup                Install uv + pnpm inside Exegol

  ${GREEN}tmux${RESET}    attach|create|kill|ls tmux session management
  ${GREEN}log${RESET}     <cmd...>             Run command + log to commands.log

  ${GREEN}info${RESET}                         Show current engagement info
  ${GREEN}help${RESET}                         This message

${BOLD}QUICKSTART${RESET}
  dotsec new mytarget example.com
  dotsec proxy up
  dotsec browser

${BOLD}CONFIG${RESET}
  DOTSEC_HOME=${DOTSEC_HOME}
EOF
    exit 0
}

# ── Proxy commands ──────────────────────────────────────
proxy_up() {
    local target="${TARGET:-default}"
    local proxy_port="${PROXY_PORT:-9999}"
    local web_port="${WEB_PORT:-9998}"

    __require_docker
    __docker_network_ensure

    printf '%b\n' "${CYAN}[*] Starting mitmproxy for ${target}...${RESET}"
    local ws="${WORKSPACE:-/workspace/${target}}"
    mkdir -p "${ws}/proxy/certs" "${ws}/proxy/flows"
    TARGET="${target}" \
        PROXY_PORT="${proxy_port}" \
        WEB_PORT="${web_port}" \
        PROXY_CERTS="${ws}/proxy/certs" \
        PROXY_FLOWS="${ws}/proxy/flows" \
        docker compose -f "${DOTSEC_HOME}/mitmproxy/docker-compose.yml" \
        --project-name "dotsec-${target}" up -d --build

    printf '%b\n' "${GREEN}[+] Proxy ready${RESET}"
    printf '%b\n' "  Proxy  → ${YELLOW}http://127.0.0.1:${proxy_port}${RESET}"
    printf '%b\n' "  Web UI → ${YELLOW}http://127.0.0.1:${web_port}${RESET}"
    printf '%b\n' "  CA PEM → ${YELLOW}${ws}/proxy/certs/mitmproxy-ca-cert.pem${RESET}"

    __homer_reload_if_running
}

proxy_down() {
    local target="${TARGET:-default}"
    docker compose -f "${DOTSEC_HOME}/mitmproxy/docker-compose.yml" \
        --project-name "dotsec-${target}" down
    printf '%b\n' "${GREEN}[+] Proxy stopped for ${target}${RESET}"
}

proxy_status() {
    local target="${TARGET:-default}"
    docker ps --filter "name=mitmproxy-${target}" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
}

proxy_logs() {
    local target="${TARGET:-default}"
    docker logs -f "mitmproxy-${target}"
}

# ── Shared tmux session spawn ────────────────────────────
__tmux_spawn_session() {
    local session_name="${1}"
    local load_cmd="${2:-}"

    tmux has-session -t "$session_name" 2>/dev/null && tmux kill-session -t "$session_name"
    tmux new-session -d -s "$session_name" -n recon
    tmux new-window  -t "$session_name" -n scan
    tmux new-window  -t "$session_name" -n exploit
    tmux new-window  -t "$session_name" -n post
    tmux new-window  -t "$session_name" -n report
    tmux new-window  -t "$session_name" -n monitor

    if [[ -n "$load_cmd" ]]; then
        for w in recon scan exploit post report monitor; do
            tmux send-keys -t "${session_name}:${w}" "${load_cmd}" Enter
        done
    fi

    tmux set-option -t "$session_name" status-right "#[fg=cyan]${session_name}#[default] | %H:%M"
    tmux set-option -t "$session_name" status-style "bg=#1a1a2e,fg=#e0e0e0"
    tmux set-option -t "$session_name" window-status-current-style "bg=#00ff87,fg=#0a0a0a,bold"
}

# ── Engagement commands ─────────────────────────────────
cmd_new() {
    local target="${1:-}"
    local domain="${2:-${target}}"

    __require_docker
    __require_tmux

    if [[ -z "$target" ]]; then
        printf '%b\n' "${RED}[!] Usage: dotsec new <target> [domain]${RESET}" >&2
        exit 1
    fi

    local ws="/workspace/${target}"

    printf '%b\n' "${BOLD}${GREEN}╔══════════════════════════════════════╗${RESET}"
    printf '%b\n' "${BOLD}${GREEN}║  New Engagement: ${target}${RESET}"
    printf '%b\n' "${BOLD}${GREEN}╚══════════════════════════════════════╝${RESET}"

    # 1. Workspace structure
    printf '%b\n' "${CYAN}[1/4] Creating workspace...${RESET}"
    mkdir -p "${ws}"/{recon/{passive,active},scans/{ports,web,vuln},exploits/{pocs,payloads},loot/{credentials,data},logs,report/assets,replays/{recon,scan,exploit,post,report,monitor}}

    # 2. Copy and fill .env
    printf '%b\n' "${CYAN}[2/4] Setting up dotenv...${RESET}"
    cp "${DOTSEC_HOME}/templates/.env.engagement" "${ws}/.env"
    sed -i "s/acme-corp/${target}/g" "${ws}/.env"
    sed -i "s/acme-corp\.com/${domain}/g" "${ws}/.env"
    sed -i "s|/workspace/acme-corp|/workspace/${target}|g" "${ws}/.env"

    # Merge global config defaults (only if key not already set)
    __dotsec_load_global
    [[ -n "${UA:-}" ]] && sed -i "s|H1-yourhandle|${UA}|g" "${ws}/.env"
    [[ -n "${EXEGOL_CONTAINER:-}" ]] && sed -i "s|exegol-default|${EXEGOL_CONTAINER}|g" "${ws}/.env"
    [[ -n "${PROXY_PORT:-}" ]] && sed -i "s|PROXY_PORT=\"9999\"|PROXY_PORT=\"${PROXY_PORT}\"|g" "${ws}/.env"
    [[ -n "${WEB_PORT:-}" ]] && sed -i "s|WEB_PORT=\"9998\"|WEB_PORT=\"${WEB_PORT}\"|g" "${ws}/.env"

    # 3. ENGAGEMENT.md
    cat > "${ws}/ENGAGEMENT.md" <<DOC
# Engagement: ${target}

- **Date**: $(date '+%Y-%m-%d %H:%M')
- **Domain**: ${domain}
- **Workspace**: ${ws}
- **Proxy**: http://127.0.0.1:\${PROXY_PORT:-8080}

## Scope
TODO

## Rules of Engagement
TODO

## User-Agent
\${UA:-not set}
DOC

    # 4. tmux session
    printf '%b\n' "${CYAN}[3/4] Creating tmux session...${RESET}"
    __tmux_spawn_session "${target}" "source ${ws}/.env && export TARGET=${target} DOMAIN=${domain}"

    # 5. Proxy setup
    printf '%b\n' "${CYAN}[4/4] Preparing proxy links...${RESET}"
    mkdir -p "${ws}/proxy" && ln -sfn "${ws}/proxy" "$(pwd)/proxy-${target}" 2>/dev/null || true

    echo ""
    printf '%b\n' "${BOLD}${GREEN}[✓] Engagement '${target}' ready!${RESET}"
    echo ""
    printf '%b\n' "  ${BOLD}Workspace${RESET}  → ${ws}"
    printf '%b\n' "  ${BOLD}Load env${RESET}    → ${YELLOW}dotsec load ${target}${RESET}"
    printf '%b\n' "  ${BOLD}Start proxy${RESET}  → ${YELLOW}dotsec proxy up${RESET}"
    printf '%b\n' "  ${BOLD}Attach tmux${RESET}  → ${YELLOW}dotsec tmux attach${RESET}"
    printf '%b\n' "  ${BOLD}Browser${RESET}     → ${YELLOW}dotsec browser${RESET}"
    printf '%b\n' "  ${BOLD}Dashboard${RESET}   → ${YELLOW}dotsec board reload${RESET}"
    echo ""

    __homer_reload_if_running
}

cmd_load() {
    local target="${1:-${TARGET:-}}"
    if [[ -z "$target" ]]; then
        printf '%b\n' "${RED}[!] Usage: dotsec load <target>${RESET}" >&2
        exit 1
    fi
    local envfile="/workspace/${target}/.env"
    if [[ ! -f "$envfile" ]]; then
        printf '%b\n' "${RED}[!] No .env found for ${target} at ${envfile}${RESET}" >&2
        printf '%b\n' "  Run ${YELLOW}dotsec new ${target}${RESET} first" >&2
        exit 1
    fi
    __dotsec_load_global
    if grep -qP '^\s*[a-zA-Z_][a-zA-Z0-9_]*=[^"]*\$\(|^\s*[a-zA-Z_][a-zA-Z0-9_]*=[^"]*`' "$envfile"; then
        printf '%b\n' "${RED}[!] .env contains command substitution — refusing to source${RESET}" >&2
        exit 1
    fi
    source "$envfile"
    printf '%b\n' "${GREEN}[+] Loaded engagement: ${TARGET}${RESET}"
    printf '%b\n' "  Workspace → ${WORKSPACE}"
    printf '%b\n' "  Proxy    → ${HTTP_PROXY}"
    printf '%b\n' "  UA       → ${UA}"
    echo ""
    printf '%b\n' "To keep vars in your shell: ${YELLOW}source <(dotsec load ${target})${RESET}"
}

cmd_unload() {
    unset TARGET DOMAIN IP UA PROGRAM PROXY_PORT WEB_PORT HTTP_PROXY HTTPS_PROXY NO_PROXY WORKSPACE
    printf '%b\n' "${GREEN}[+] Engagement vars unset${RESET}"
}

cmd_list() {
    printf '%b\n' "${BOLD}Engagements:${RESET}"
    for d in /workspace/*/; do
        [[ -d "$d" ]] || continue
        local name domain
        name=$(basename "$d")
        local env="${d}.env"
        if [[ -f "$env" ]]; then
            domain=$(__env_domain "$env")
            [[ -z "$domain" ]] && domain="?"
            printf '%b\n' "  ${CYAN}${name}${RESET}  → ${domain}"
        else
            printf '%b\n' "  ${CYAN}${name}${RESET}  (no .env)"
        fi
    done
}

# ── Browser ──────────────────────────────────────────────
cmd_browser() {
    local target="${1:-${TARGET:-}}"
    __require_docker
    if [[ -z "$target" ]]; then
        printf '%b\n' "${RED}[!] Usage: dotsec browser <target>  (or dotsec load first)${RESET}" >&2
        exit 1
    fi
    local ws="/workspace/${target}"

    # Ensure proxy is up
    if ! docker ps --filter "name=mitmproxy-${target}" --format '{{.Names}}' | grep -q .; then
        printf '%b\n' "${YELLOW}[!] Proxy not running. Starting...${RESET}" >&2
        TARGET="${target}" proxy_up
    fi

    local proxy_host="mitmproxy-${target}"
    docker run --rm \
        --network dotsec-proxy-net \
        -e HTTP_PROXY="http://${proxy_host}:8080" \
        -e HTTPS_PROXY="http://${proxy_host}:8080" \
        -v "${ws}/proxy/certs:/certs:ro" \
        -p 127.0.0.1:9222:9222 \
        dotenv-sec/chromium:latest
}

# ── Exegol ───────────────────────────────────────────────
cmd_exegol() {
    local action="${1:-shell}"; shift || true
    local container="${EXEGOL_CONTAINER:-exegol}"

    __require_docker

    local docker_tty=""
    [[ -t 0 ]] && docker_tty="-it"

    case "$action" in
        exec)
            docker exec ${docker_tty} "$container" "$@"
            ;;
        shell)
            docker exec ${docker_tty} "$container" zsh
            ;;
        setup)
            printf '%b\n' "${CYAN}[*] Running Exegol tool setup (uv + pnpm)...${RESET}"
            if ! docker ps --filter "name=^${container}$" --format '{{.Names}}' | grep -q .; then
                printf '%b\n' "${YELLOW}[!] Container '${container}' is not running.${RESET}" >&2
                printf '%b\n' "  Start it with: ${YELLOW}exegol start ${container}${RESET}" >&2
                exit 1
            fi
            docker exec ${docker_tty} "$container" bash /opt/resources/dotenv-sec/setup.sh
            ;;
        *)
            printf '%b\n' "${RED}[!] Usage: dotsec exegol exec|shell|setup${RESET}" >&2
            exit 1
            ;;
    esac
}

# ── Spawn ─────────────────────────────────────────────────
# Instant pentest-ready tmux session, with or without engagement loaded
cmd_spawn() {
    local session_name="${1:-${TARGET:-pentest}}"
    local ws="${WORKSPACE:-}"
    local envfile="${ws}/.env"

    __require_tmux

    printf '%b\n' "${CYAN}[*] Spawning tmux session: ${session_name}${RESET}"

    local spawn_cmd=""
    [[ -n "$ws" ]] && [[ -f "$envfile" ]] && spawn_cmd="source ${envfile}; clear"

    __tmux_spawn_session "$session_name" "$spawn_cmd"

    [[ -n "$spawn_cmd" ]] && printf '%b\n' "  ${GREEN}Env loaded${RESET} → ${ws}/.env"

    tmux attach -t "$session_name"
}

# ── Tmux ─────────────────────────────────────────────────
cmd_tmux() {
    local action="${1:-}"; shift || true
    local target="${TARGET:-}"
    [[ -z "$target" ]] && target="${1:-}"

    __require_tmux

    case "$action" in
        attach|a)
            [[ -z "$target" ]] && { printf '%b\n' "${RED}[!] No target. dotsec load <target> first${RESET}" >&2; exit 1; }
            tmux attach -t "$target"
            ;;
        create)
            [[ -z "$target" ]] && { printf '%b\n' "${RED}[!] Usage: dotsec tmux create <target>${RESET}" >&2; exit 1; }
            __tmux_spawn_session "$target"
            printf '%b\n' "${GREEN}[+] Session ${target} created${RESET}"
            ;;
        kill|k)
            [[ -z "$target" ]] && { printf '%b\n' "${RED}[!] Usage: dotsec tmux kill <target>${RESET}" >&2; exit 1; }
            tmux kill-session -t "$target"
            printf '%b\n' "${GREEN}[+] Session ${target} killed${RESET}"
            ;;
        ls|list)
            tmux ls 2>/dev/null || echo "No sessions"
            ;;
        *)
            printf '%b\n' "${RED}[!] Usage: dotsec tmux attach|create|kill|ls${RESET}" >&2
            ;;
    esac
}

# ── Log ───────────────────────────────────────────────────
cmd_log() {
    local target="${TARGET:-}"
    [[ -z "$target" ]] && { printf '%b\n' "${RED}[!] No engagement loaded${RESET}" >&2; exit 1; }
    local logfile="/workspace/${target}/logs/commands.log"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$logfile"
    "$@"
}

# ── Dashboard (Homer) ────────────────────────────────────
__homer_gen_config() {
    local config="${DOTSEC_HOME}/homer/config.yml"
    local base="${DOTSEC_HOME}/homer/config.base.yml"

    # Use base template if available, else inline
    if [[ -f "$base" ]]; then
        cp "$base" "$config"
    else
        cat > "$config" <<'YAML'
---
title: "dotenv-sec"
subtitle: "Pentest Dashboard"
header: true
footer: false
columns: "auto"
connectivityCheck: true
theme: dark
colors:
  light:
    highlight-primary: "#00ff87"
    highlight-secondary: "#00d4ff"
    background: "#0a0a0f"
    card-background: "#1a1a2e"
    text: "#e0e0e0"
    text-header: "#00ff87"
    text-title: "#ffffff"
    text-subtitle: "#ccd6f6"
    card-shadow: "rgba(0,255,135,0.1)"
    link: "#00d4ff"
    link-hover: "#00ff87"
  dark:
    highlight-primary: "#00ff87"
    highlight-secondary: "#00d4ff"
    background: "#0a0a0f"
    card-background: "#1a1a2e"
    text: "#e0e0e0"
    text-header: "#00ff87"
    text-title: "#ffffff"
    text-subtitle: "#ccd6f6"
    card-shadow: "rgba(0,255,135,0.1)"
    link: "#00d4ff"
    link-hover: "#00ff87"
YAML
    fi

    # Inject services
    cat >> "$config" <<YAML

services:
YAML

    # Detection d'engagements actifs
    local found=0
    for d in /workspace/*/; do
        [[ -d "$d" ]] || continue
        local target domain
        target=$(basename "$d")
        local envfile="${d}.env"
        domain=""

        [[ -f "$envfile" ]] && domain=$(__env_domain "$envfile")
        [[ -z "$domain" ]] && domain="${target}"

        # Check if proxy is running
        local proxy_status="down"
        docker ps --filter "name=mitmproxy-${target}" --format '{{.Names}}' 2>/dev/null | grep -q . && proxy_status="up"

        cat >> "$config" <<BLOCK
  - name: "${target}"
    icon: "fas fa-crosshairs"
    subtitle: "${domain}"
    items:
      - name: "Proxy: ${proxy_status}"
        icon: "fas fa-network-wired"
        subtitle: "127.0.0.1:9999"
        url: "http://127.0.0.1:9999"
        target: "_blank"
      - name: "mitmweb UI"
        icon: "fas fa-globe"
        subtitle: "127.0.0.1:9998"
        url: "http://127.0.0.1:9998"
        target: "_blank"
      - name: "Workspace"
        icon: "fas fa-folder"
        subtitle: "${target}"
        url: "file:///workspace/${target}"
      - name: "ENGAGEMENT.md"
        icon: "fas fa-file-alt"
        subtitle: "scope, rules"
        url: "file:///workspace/${target}/ENGAGEMENT.md"
BLOCK
        found=1
    done

    # Fallback if no engagements
    if [[ $found -eq 0 ]]; then
        cat >> "$config" <<YAML
  - name: "No engagements"
    icon: "fas fa-circle-notch"
    items:
      - name: "Create one"
        icon: "fas fa-plus"
        subtitle: "dotsec new <target>"
        url: "#"
YAML
    fi

    echo "  → ${config}"
}

cmd_dashboard() {
    local action="${1:-status}"

    __require_docker

    case "$action" in
        up|start)
            printf '%b\n' "${CYAN}[*] Generating Homer config...${RESET}"
            __homer_gen_config

            printf '%b\n' "${CYAN}[*] Starting Homer dashboard...${RESET}"
            __docker_network_ensure

            docker compose -f "${DOTSEC_HOME}/homer/docker-compose.yml" \
                --project-name "dotsec-homer" up -d

            printf '%b\n' "${GREEN}[+] Dashboard ready${RESET}"
            printf '%b\n' "  → ${YELLOW}http://127.0.0.1:${HOMER_PORT:-9997}${RESET}"
            ;;
        down|stop)
            docker compose -f "${DOTSEC_HOME}/homer/docker-compose.yml" \
                --project-name "dotsec-homer" down
            printf '%b\n' "${GREEN}[+] Dashboard stopped${RESET}"
            ;;
        reload)
            printf '%b\n' "${CYAN}[*] Regenerating config + restarting...${RESET}"
            __homer_gen_config
            docker restart dotsec-homer 2>/dev/null || \
                { printf '%b\n' "${YELLOW}[!] Homer not running, starting...${RESET}" >&2; cmd_dashboard up; }
            printf '%b\n' "${GREEN}[+] Dashboard reloaded${RESET}"
            ;;
        status)
            docker ps --filter "name=dotsec-homer" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
            ;;
        *)
            printf '%b\n' "${RED}[!] Usage: dotsec dashboard up|down|reload|status${RESET}" >&2
            ;;
    esac
}
cmd_info() {
    printf '%b\n' "${BOLD}dotsec v${VERSION}${RESET}"
    echo ""
    printf '%b\n' "  ${BOLD}TARGET${RESET}     = ${TARGET:-not set}"
    printf '%b\n' "  ${BOLD}DOMAIN${RESET}     = ${DOMAIN:-not set}"
    printf '%b\n' "  ${BOLD}WORKSPACE${RESET}  = ${WORKSPACE:-not set}"
    printf '%b\n' "  ${BOLD}HTTP_PROXY${RESET} = ${HTTP_PROXY:-not set}"
    printf '%b\n' "  ${BOLD}UA${RESET}         = ${UA:-not set}"
    printf '%b\n' "  ${BOLD}EXEGOL${RESET}     = ${EXEGOL_CONTAINER:-not set}"
    echo ""
    printf '%b\n' "  ${BOLD}DOTSEC_HOME${RESET} = ${DOTSEC_HOME}"
    printf '%b\n' "  ${BOLD}DOTSEC_CONFIG${RESET}= ${DOTSEC_CONFIG} $([ -f "${DOTSEC_CONFIG}/config" ] && echo '(loaded)' || echo '(missing)')"
}

# ── Routeur ───────────────────────────────────────────────
case "${1:-help}" in
    new)          shift; cmd_new "$@";;
    load)         shift; cmd_load "$@";;
    unload)       cmd_unload;;
    list|ls)      cmd_list;;

    spawn)        shift; cmd_spawn "$@";;

    proxy)
        case "${2:-status}" in
            up)      proxy_up;;
            down)    proxy_down;;
            status)  proxy_status;;
            logs)    proxy_logs;;
            *)       printf '%b\n' "${RED}[!] dotsec proxy up|down|status|logs${RESET}" >&2;;
        esac
        ;;

    browser)      shift; cmd_browser "$@";;
    board|dashboard)
        case "${2:-status}" in
            up|start|down|stop|reload|status)
                shift; cmd_dashboard "$@";;
            *)  printf '%b\n' "${RED}[!] dotsec board up|down|reload|status${RESET}" >&2;;
        esac
        ;;
    exegol)       shift; cmd_exegol "$@";;
    tmux)         shift; cmd_tmux "$@";;
    log)          shift; cmd_log "$@";;
    info)         cmd_info;;
    completions)  shift; exec "${DOTSEC_HOME}/bin/dotsec-completions" "$@";;
    help|--help|-h) usage;;
    *)            printf '%b\n' "${RED}[!] Unknown command: $1${RESET}" >&2; usage;;
esac
