#!/usr/bin/env bash
# ─── dotsec ─── dotenv-sec launcher ─────────────────────
set -euo pipefail

DOTSEC_HOME="${DOTSEC_HOME:-$HOME/Documents/github.com/Dxsk/dotenv-sec}"
DOTSEC_CONFIG="${DOTSEC_CONFIG:-$HOME/.config/dotenvsec}"
# shellcheck disable=SC2034  # consumed by usage()/cmd_info in sourced libs
VERSION="0.2.0"

# Workspace root: /workspace (Exegol) or fallback to ~/workspace
if [[ -z "${WORKSPACE_ROOT:-}" ]]; then
    if [[ -w "/workspace" ]] || [[ -d "/workspace" ]]; then
        WORKSPACE_ROOT="/workspace"
    else
        WORKSPACE_ROOT="${HOME}/workspace"
    fi
fi

DOTSEC_LIB="${DOTSEC_HOME}/lib"
for _m in ui core secrets dashboard proxy exegol engagement; do
    # shellcheck source=/dev/null
    source "${DOTSEC_LIB}/${_m}.sh"
done
__dotsec_load_global

# ── Routeur ───────────────────────────────────────────────
case "${1:-help}" in
    new)          shift; cmd_new "$@";;
    load)         shift; cmd_load "$@";;
    unload)       cmd_unload;;
    list|ls)      cmd_list;;

    spawn)        shift; cmd_spawn "$@";;

    proxy)
        case "${2:-status}" in
            up)      proxy_up;;
            down)    proxy_down;;
            status)  proxy_status;;
            logs)    proxy_logs;;
            *)       printf '%b\n' "${RED}[!] dotsec proxy up|down|status|logs${RESET}" >&2;;
        esac
        ;;

    browser)      shift; cmd_browser "$@";;
    board|dashboard)
        case "${2:-status}" in
            up|start|down|stop|reload|status)
                shift; cmd_dashboard "$@";;
            *)  printf '%b\n' "${RED}[!] dotsec board up|down|reload|status${RESET}" >&2;;
        esac
        ;;
    exegol)       shift; cmd_exegol "$@";;
    tmux)         shift; cmd_tmux "$@";;
    log)          shift; cmd_log "$@";;
    archive)      shift; cmd_archive "$@";;
    stop)         shift; cmd_stop "$@";;
    restart)      shift; cmd_restart "$@";;
    secrets)
        shift
        _t="${1:-${TARGET:-}}"
        [[ -z "$_t" ]] && { printf '%b\n' "${RED}[!] Usage: dotsec secrets <target>${RESET}" >&2; exit 1; }
        secrets_show "${WORKSPACE_ROOT}/${_t}"
        ;;
    rotate)
        shift
        _t="${1:-${TARGET:-}}"; _type="${2:-all}"
        [[ -z "$_t" ]] && { printf '%b\n' "${RED}[!] Usage: dotsec rotate <target> [all|token|mitmweb|ssh|ca]${RESET}" >&2; exit 1; }
        if [[ "$_type" == "ssh" || "$_type" == "ca" || "$_type" == "all" ]]; then
            printf '%b' "${YELLOW}[?]${RESET} Rotate '${_type}' for ${_t}? This invalidates deployed keys / CA trust. [y/N] " >&2
            read -r _ans
            [[ "$_ans" =~ ^[Yy]$ ]] || { printf '%b\n' "${DIM}Aborted${RESET}" >&2; exit 0; }
        fi
        secrets_rotate "${WORKSPACE_ROOT}/${_t}" "$_type"
        printf '%b\n' "${GREEN}Rotated${RESET} ${CYAN}${_t}${RESET} ${DIM}(${_type})${RESET}"
        ;;
    info)         cmd_info;;
    completions)  shift; exec "${DOTSEC_HOME}/bin/dotsec-completions" "$@";;
    help|--help|-h) usage;;
    *)            printf '%b\n' "${RED}[!] Unknown command: $1${RESET}" >&2; usage;;
esac
